<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- JIT requis par JPype/JVM pour allouer de la mémoire exécutable -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- JVM alloue de la mémoire non signée (interpréteur bytecode) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- UCanAccess charge des bibliothèques natives non signées (JARs) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Accès aux fichiers choisis par l'utilisateur (.accdb, .xlsx) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
